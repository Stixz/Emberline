{
  "name": "google-apps-gateway",
  "version": "1.0.0",
  "productName": "Google Apps Gateway",
  "author": "Ravenforge Creations",
  "description": "A clean control panel for accessing Google Apps",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:signed": "electron-builder --config.win.signAndEditExecutable=true --config.forceCodeSigning=true"
  },
  "build": {
    "appId": "com.ravenforge.googleappsgateway",
    "productName": "Google Apps Gateway",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "config.json",
      "package.json",
      "build/icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
